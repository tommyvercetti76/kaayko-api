rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin users collection - API-only writes, authenticated reads
    match /admin_users/{userId} {
      // Users can read their own profile
      allow read: if request.auth != null && request.auth.uid == userId;
      // Only Cloud Functions can write (via Admin SDK)
      allow write: if false;
    }
    
    // Short links collection - Public reads for redirects, API-only writes
    match /short_links/{linkId} {
      // Public read access (needed for redirect functionality)
      allow read: if true;
      // Only Cloud Functions can write
      allow write: if false;
    }
    
    // Link analytics - Write by authenticated users, read by admins
    match /link_analytics/{analyticsId} {
      // Anyone can write analytics (for tracking)
      allow create: if true;
      // Only Cloud Functions can read/update/delete
      allow read, update, delete: if false;
    }
    
    // Forecast cache - Public reads, API-only writes
    match /forecast_cache/{cacheId} {
      allow read: if true;
      allow write: if false;
    }
    
    // ========================================
    // STORE COLLECTIONS
    // ========================================

    // Products — public read (catalog browsing), API-only writes
    match /kaaykoproducts/{productId} {
      allow read: if true;
      allow write: if false;
    }

    // Orders — API-only access (all reads/writes via Cloud Functions Admin SDK)
    match /orders/{orderId} {
      allow read, write: if false;
    }

    // Payment intents — API-only access
    match /payment_intents/{paymentIntentId} {
      allow read, write: if false;
    }

    // ========================================
    // KREATOR COLLECTIONS
    // ========================================
    
    // Kreator applications - API-only access
    match /kreator_applications/{applicationId} {
      // Public can check their own application status via API
      // All writes go through Cloud Functions
      allow read, write: if false;
    }
    
    // Kreators collection - API-only writes, kreators can read own
    match /kreators/{kreatorId} {
      // Kreators can read their own profile
      allow read: if request.auth != null && request.auth.uid == kreatorId;
      // Only Cloud Functions can write
      allow write: if false;
    }
    
    // Admin audit logs - API-only access
    match /admin_audit_logs/{logId} {
      allow read, write: if false;
    }
    
    // ========================================
    // KALEKUTZ — nutrition tracker (per-user, uid-scoped)
    // ========================================

    match /users/{userId} {
      // KaleKutz profile (BMR, targets)
      match /kutzProfile/{document} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Daily nutrition logs
      match /kutzDays/{dayId} {
        allow read, create: if request.auth != null && request.auth.uid == userId;
        // Allow update only if day isn't already locked (or if unlocking it)
        allow update: if request.auth != null && request.auth.uid == userId
          && !(resource.data.locked == true && request.resource.data.locked == true);

        // Foods subcollection
        match /foods/{foodId} {
          allow read: if request.auth != null && request.auth.uid == userId;
          allow create, delete: if request.auth != null && request.auth.uid == userId
            && (!exists(/databases/$(database)/documents/users/$(userId)/kutzDays/$(dayId))
                || get(/databases/$(database)/documents/users/$(userId)/kutzDays/$(dayId)).data.locked != true);
        }

        // Exercise log subcollection (not locked — always editable)
        match /exercises/{exerciseId} {
          allow read, create, delete: if request.auth != null && request.auth.uid == userId;
        }
      }

      // Frequent foods for quick-add bar
      match /kutzFrequentFoods/{foodId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Branded product overrides (label-accurate macros for packaged foods)
      // User can read their own; writes go through the Cloud Function (Admin SDK)
      match /kutzProductDB/{productId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Daily weight log entries
      match /kutzWeightLog/{dateId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Saved recipes (home-cooked meals with ingredient lists + per-serving macros)
      match /kutzRecipes/{recipeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // All other collections - deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
