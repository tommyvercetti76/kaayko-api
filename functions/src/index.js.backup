// Global error handler
apiApp.use((error, req, res, next) => {
  const duration = Date.now() - req.startTime;
  console.error(`[${req.requestId}] Global error after ${duration}ms:`, {
    error: error.message,
    stack: CONFIG.environment.isDevelopment ? error.stack : undefined,
    path: req.path,
    method: req.method
  });
  
  res.status(500).json({
    error: 'Internal server error',
    requestId: req.requestId,
    timestamp: new Date().toISOString(),
    details: CONFIG.environment.isDevelopment ? error.message : undefined
  });
});

// Export main API function with enhanced configuration
console.log("🌟 Exporting main API function...");
exports.api = functions
  .region('us-central1')
  .runWith({
    timeoutSeconds: 540,
    memory: '1GB'
  })
  .https.onRequest(apiApp);

console.log("✅ Main API function exported successfully");

// Ultra-fast forecast API - NOW ENABLED with configuration
