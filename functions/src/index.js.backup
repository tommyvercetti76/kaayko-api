const admin     = require("firebase-admin");
const express   = require("express");
const cors      = require("cors");
const CONFIG    = require("./config/apiConfig");

console.log(`🚀 Kaayko API starting in ${CONFIG.environment.nodeEnv} mode`);
console.log(`📍 Environment: ${CONFIG.environment.isDevelopment ? 'Development' : 'Production'}`);
console.log(`🔧 Emulator: ${CONFIG.environment.isEmulator ? 'Yes' : 'No'}`);

// Initialize Firebase Admin
admin.initializeApp();
console.log(`✅ Firebase Admin initialized for project: ${CONFIG.firebase.projectId}`);

// Create Express app for JSON API with enhanced configuration
const apiApp = express();

// Enhanced CORS setup based on environment
const corsOptions = {
  origin: CONFIG.environment.isDevelopment ? true : [
    'http://localhost:5000',
    'https://kaaykostore.web.app',
    'https://kaaykostore.firebaseapp.com'
  ],
  credentials: true,
  methods: ['GET', 'POST', 'PUT', 'DELETE', 'OPTIONS'],
  allowedHeaders: ['Content-Type', 'Authorization', 'X-Requested-With']
};

apiApp.use(cors(corsOptions));
apiApp.use(express.json({ limit: '10mb' }));
apiApp.use(express.urlencoded({ extended: true }));

// Request logging middleware
apiApp.use((req, res, next) => {
  const startTime = Date.now();
  const requestId = Math.random().toString(36).substring(2, 8);
  
  req.requestId = requestId;
  req.startTime = startTime;
  
  console.log(`[${requestId}] ${req.method} ${req.path} - Start`);
  
  // Log response completion
  const originalSend = res.send;
  res.send = function(data) {
    const duration = Date.now() - startTime;
    console.log(`[${requestId}] ${req.method} ${req.path} - ${res.statusCode} (${duration}ms)`);
    return originalSend.call(this, data);
  };
  
  next();
});

// Health check and debugging endpoints with enhanced info
apiApp.get("/", (req, res) => {
  res.json({
    message: "Kaayko API is running!",
    version: "1.2.0",
    environment: CONFIG.environment.nodeEnv,
    timestamp: new Date().toISOString(),
    requestId: req.requestId,
    endpoints: {
      health: "/test",
      products: "/products",
      images: "/images", 
      paddlingOut: "/paddlingOut",
      paddlePredict: "/paddlePredict"
    }
  });
});

apiApp.get("/helloWorld", (req, res) => {
  res.json({
    message: "Hello from Kaayko!",
    requestId: req.requestId,
    timestamp: new Date().toISOString()
  });
});

apiApp.get("/test", (req, res) => {
  res.json({
    status: "API is working",
    environment: CONFIG.environment,
    firebase: {
      projectId: CONFIG.firebase.projectId,
      storageBucket: CONFIG.firebase.storageBucket
    },
    cache: CONFIG.cache,
    requestId: req.requestId,
    timestamp: new Date().toISOString()
  });
});

// Essential API routes used by frontend - ALL PRESERVED
console.log("📦 Loading API modules...");

try {
  const productsAPI = require("./api/products");
  apiApp.use("/products", productsAPI);
  console.log("✅ Products API loaded");
} catch (error) {
  console.error("❌ Failed to load Products API:", error.message);
}

try {
  const imagesAPI = require("./api/images");
  apiApp.use("/images", imagesAPI);
  console.log("✅ Images API loaded");
} catch (error) {
  console.error("❌ Failed to load Images API:", error.message);
}

try {
  const paddlingOutAPI = require("./api/paddlingout");
  apiApp.use("/paddlingOut", paddlingOutAPI);
  console.log("✅ PaddlingOut API loaded (enhanced)");
} catch (error) {
  console.error("❌ Failed to load PaddlingOut API:", error.message);
}

try {
  const paddlePredictAPI = require("./api/paddlePredict");
  apiApp.use("/paddlePredict", paddlePredictAPI);
  console.log("✅ PaddlePredict API loaded");
} catch (error) {
  console.error("❌ Failed to load PaddlePredict API:", error.message);
}

