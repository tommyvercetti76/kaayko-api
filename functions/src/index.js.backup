try {
  const { fastForecast, cacheManager } = require('./api/fastForecast');
  exports.fastForecast = functions
    .region('us-central1')
    .runWith({
      timeoutSeconds: 60,
      memory: '512MB'
    })
    .https.onRequest(fastForecast);
    
  exports.cacheManager = functions
    .region('us-central1')
    .runWith({
      timeoutSeconds: 120,
      memory: '512MB'
    })
    .https.onRequest(cacheManager);
    
  console.log("✅ FastForecast API exported");
} catch (error) {
  console.log("⚠️  FastForecast API not loaded:", error.message);
}


