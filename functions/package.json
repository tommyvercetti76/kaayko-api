{
  "name": "kaayko-api",
  "description": "Kaayko Store REST API (Cloud Functions) with ML Support",
  "private": true,
  "engines": {
    "node": "22",
    "python": "3.9"
  },
  "main": "index.js",
  "scripts": {
    "serve": "firebase emulators:start --only functions,firestore,storage",
    "deploy": "firebase deploy --only functions",
    "deploy:fast": "firebase deploy --only functions:fastForecast,functions:cacheManager",
    "deploy:scheduled": "firebase deploy --only functions:precomputeForecasts,functions:cleanupCache",
    "test": "jest --verbose --forceExit --detectOpenHandles",
    "test:ci": "jest --ci --forceExit --detectOpenHandles --coverage",
    "test:watch": "jest --watch --forceExit",
    "test:integration": "jest --config jest.integration.config.js --forceExit --detectOpenHandles",
    "test:integration:verbose": "jest --config jest.integration.config.js --forceExit --detectOpenHandles --verbose",
    "test:all": "npm test && npm run test:integration",
    "emulators": "firebase emulators:start --only firestore,auth",
    "emulators:bg": "firebase emulators:start --only firestore,auth &",
    "emulators:full": "firebase emulators:start --only functions,firestore,auth",
    "seed": "node scripts/seed-emulator.js",
    "test:performance": "node ../tests/firebase_performance_test.js",
    "install-python": "pip3 install -r requirements.txt",
    "postinstall": "pip3 install -r requirements.txt || echo 'Python dependencies installation failed, will fallback to JS'"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "firebase-admin": "^13.2.0",
    "firebase-functions": "^7.0.3",
    "multer": "^2.0.2",
    "openai": "^4.77.0",
    "stripe": "^17.5.0",
    "uuid": "^9.0.1",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "supertest": "^7.2.2"
  }
}
